# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
dev.log

# env files (can opt-in for committing if needed)
.env*
!.env.example

# user-uploaded media
/public/uploads/*
!/public/uploads/.gitkeep

# local database backups (never commit)
/backups/

# PlatformIO / embedded firmware build artifacts
esp32-touch/.pio/
esp32-touch/include/secrets.h

# whatsapp-web.js session
.whatsapp-auth/
.wwebjs_cache/

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Local dev server logs
dev3000.log
dev3001.log
*.log
