generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL") // app runtime (Supabase: direct db.<ref>, or 6543 pooler on serverless)
  directUrl = env("DIRECT_URL") // migrations (Supabase: direct db.<ref>:5432, or session pooler if IPv4-only)
}

enum VisitStatus {
  TO_VISIT
  VISITED
}

enum MediaType {
  UPLOAD
  IMAGE_URL
  LINK
}

enum UserRole {
  OWNER
  EDITOR
  VIEWER
}

enum MapTheme {
  CLASSIC
  FLAG
}

enum FriendStatus {
  PENDING
  ACCEPTED
}

enum NotificationType {
  FRIEND_REQUEST
  FRIEND_ACCEPTED
}

model User {
  id           String     @id @default(cuid())
  username     String     @unique
  passwordHash String     @default("")
  clerkId      String?    @unique
  imageUrl     String?
  email        String?
  role         UserRole   @default(EDITOR)
  mapTheme     MapTheme   @default(CLASSIC)
  homeAirports String[]   @default([])
  usaAsStates  Boolean    @default(false) /// show US states as independent map units
  visitedRegions String[] @default([]) /// Passport: visited country (ISO-3) / US-state (US-XX) codes; independent of Location, no effect on wish glow
  passportOnboardedAt DateTime? /// when the user finished/dismissed the "map where you've been" onboarding (null = show it once)
  maxTravelHours  Int     @default(24)
  maxLayoverHours Int        @default(8)
  cabin           String     @default("any")
  nonstopOnly     Boolean    @default(false)
  tripStyles      String[]   @default([])
  flightPref      String     @default("both")   /// "international", "domestic", "both"
  distancePref    String     @default("no_preference") /// "farther", "nearby", "no_preference"
  preferFarther   Boolean    @default(false)
  loyaltyPrograms String[]   @default([])      /// array of program IDs
  heldCards       String[]   @default([])      /// array of card IDs
  onboarded       Boolean    @default(false)
  locations    Location[]
  drafts       Draft[]
  sentFriendRequests     Friendship[]   @relation("SentFriendRequests")
  receivedFriendRequests Friendship[]   @relation("ReceivedFriendRequests")
  notifications          Notification[] @relation("RecipientNotifications")
  actorNotifications     Notification[] @relation("ActorNotifications")
  createdAt    DateTime   @default(now())

  // Meridian relations
  watches              Watch[]
  trips                Trip[]
  tripPlans            TripPlan[]
  journalEntries       JournalEntry[]
  cardProfiles         CardProfile[]
  loyaltyBalances      LoyaltyBalance[]
  createdBoards        SocialBoard[]
  boardDeals           BoardDeal[]
  boardComments        BoardComment[]
  gamificationProgress GamificationProgress?
  notificationPref     NotificationPref?
  passwordResets       PasswordReset[]
  dealVotes            DealVote[]
}

/// A friend link between two users. One row per (requester, addressee) pair;
/// starts PENDING when requested, flips to ACCEPTED once the addressee accepts.
model Friendship {
  id          String       @id @default(cuid())
  requester   User         @relation("SentFriendRequests", fields: [requesterId], references: [id], onDelete: Cascade)
  requesterId String
  addressee   User         @relation("ReceivedFriendRequests", fields: [addresseeId], references: [id], onDelete: Cascade)
  addresseeId String
  status      FriendStatus @default(PENDING)
  createdAt   DateTime     @default(now())
  respondedAt DateTime?

  @@unique([requesterId, addresseeId])
  @@index([addresseeId, status])
  @@index([requesterId, status])
}

/// Inbox notification (friend request received / request accepted). `user` is
/// the recipient; `actor` is whoever triggered it.
model Notification {
  id           String           @id @default(cuid())
  user         User             @relation("RecipientNotifications", fields: [userId], references: [id], onDelete: Cascade)
  userId       String
  type         NotificationType
  actor        User?            @relation("ActorNotifications", fields: [actorId], references: [id], onDelete: SetNull)
  actorId      String?
  friendshipId String?
  read         Boolean          @default(false)
  createdAt    DateTime         @default(now())

  @@index([userId, read, createdAt])
}

/// One wishlist/journal entry
model Location {
  id             String        @id @default(cuid())
  activityName   String
  countryCode    String /// ISO-3166 alpha-3
  countryName    String
  region         String?
  city           String?
  latitude       Float
  longitude      Float
  status         VisitStatus   @default(TO_VISIT)
  notes          String?
  reminderAt     DateTime?
  priceThreshold Float?
  starred        Boolean       @default(false)
  sortOrder      Int           @default(0) /// manual order within a country list (lower = higher up)
  isPublic       Boolean       @default(false) /// published to the public feed (the rest of the board stays private)
  coverImageUrl  String?
  seasonSpring   Boolean       @default(false)
  seasonSummer   Boolean       @default(false)
  seasonFall     Boolean       @default(false)
  seasonWinter   Boolean       @default(false)
  media          Media[]
  flightPrices   FlightPrice[]
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId         String
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([countryCode])
  @@index([userId])
  @@index([isPublic, createdAt])
}

model Media {
  id         String    @id @default(cuid())
  location   Location  @relation(fields: [locationId], references: [id], onDelete: Cascade)
  locationId String
  type       MediaType
  url        String
  caption    String?
  sortOrder  Int       @default(0)
}

model FlightPrice {
  id          String   @id @default(cuid())
  location    Location @relation(fields: [locationId], references: [id], onDelete: Cascade)
  locationId  String
  price       Float
  currency    String   @default("USD")
  origin      String?
  destination String?
  source      String?
  fetchedAt   DateTime @default(now())

  @@index([locationId, fetchedAt])
}

/// Unsorted inbox items (e.g. shared Instagram reels via WhatsApp)
model Draft {
  id           String   @id @default(cuid())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId       String
  rawText      String?
  extractedUrl String?
  source       String   @default("whatsapp")
  createdAt    DateTime @default(now())

  @@index([userId, createdAt])
}

/// Image bytes captured into the shared DB (e.g. an Instagram reel cover).
/// cdninstagram URLs are signed and short-lived, so they break on another
/// machine or after a while; we copy the bytes here once and serve them via
/// /api/stored-image/[id] so the cover is stable everywhere.
model StoredImage {
  id        String   @id @default(cuid())
  mime      String   @default("image/jpeg")
  bytes     Bytes
  source    String   @default("instagram")
  createdAt DateTime @default(now())
}

/// Cached Google Images (Serper.dev) results, keyed by normalized query.
/// Lets repeat lookups skip the external API entirely (0 credit cost).
model ImageCache {
  id          String   @id @default(cuid())
  searchQuery String   @unique /// normalized: trimmed, lowercased, single-spaced
  images      Json /// PreviewImage[] — see src/lib/serperImages.ts
  source      String   @default("serper")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ─── Meridian Feature Models ─────────────────────────────────────────────────

enum TripPlanStatus {
  DRAFT
  PLANNED
  BOOKED
  COMPLETED
  CANCELLED
}

/// Cached flight fares from external providers
model FareCache {
  id           String   @id @default(cuid())
  origin       String
  destination  String
  flyToCode    String
  month        Int
  outboundDate DateTime?
  returnDate   DateTime?
  price        Float
  currency     String   @default("USD")
  airline      String?
  source       String?
  dealScore    Float?
  tier         String?
  lastSeen     DateTime @default(now())
  createdAt    DateTime @default(now())

  @@index([origin, destination])
  @@index([origin, month])
  @@index([flyToCode])
}

/// Append-only price history for routes
model FareHistory {
  id          String   @id @default(cuid())
  origin      String
  destination String
  month       Int
  price       Float
  source      String?
  recordedAt  DateTime @default(now())

  @@index([origin, destination])
  @@index([recordedAt])
}

/// User price watches on routes
model Watch {
  id              String     @id @default(cuid())
  user            User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId          String
  origin          String
  destinationCode String
  targetPrice     Float
  currency        String     @default("USD")
  active          Boolean    @default(true)
  lastChecked     DateTime?
  lastAlertedAt   DateTime?
  createdAt       DateTime   @default(now())
  alerts          AlertLog[]

  @@index([userId])
  @@index([origin, destinationCode])
}

/// Triggered alert log entries
model AlertLog {
  id          String   @id @default(cuid())
  watch       Watch    @relation(fields: [watchId], references: [id], onDelete: Cascade)
  watchId     String
  price       Float
  source      String?
  triggeredAt DateTime @default(now())

  @@index([watchId])
  @@index([triggeredAt])
}

/// Memory-map trips (places visited)
model Trip {
  id            String         @id @default(cuid())
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId        String
  code          String
  city          String
  country       String
  lat           Float
  lon           Float
  startDate     DateTime?
  endDate       DateTime?
  note          String?
  rating        Int?
  coverImageUrl String?
  createdAt     DateTime       @default(now())
  journalEntries JournalEntry[]

  @@index([userId])
  @@index([code])
}

/// Trip planner plans
model TripPlan {
  id          String         @id @default(cuid())
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId      String
  name        String
  description String?
  startDate   DateTime?
  endDate     DateTime?
  budget      Float?
  currency    String         @default("USD")
  status      TripPlanStatus @default(DRAFT)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  legs        TripPlanLeg[]

  @@index([userId])
  @@index([status])
}

/// Individual legs of a trip plan
model TripPlanLeg {
  id         String   @id @default(cuid())
  tripPlan   TripPlan @relation(fields: [tripPlanId], references: [id], onDelete: Cascade)
  tripPlanId String
  origin     String
  destination String
  departDate DateTime?
  returnDate DateTime?
  fareAmount Float?
  fareSource String?
  notes      String?
  sortOrder  Int      @default(0)

  @@index([tripPlanId])
}

/// Travel journal entries
model JournalEntry {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  trip      Trip?    @relation(fields: [tripId], references: [id], onDelete: SetNull)
  tripId    String?
  title     String
  content   String
  location  String?
  country   String?
  lat       Float?
  lon       Float?
  date      DateTime?
  mood      String?
  weather   String?
  tags      String?  /// JSON array
  photos    String?  /// JSON array
  isPublic  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([tripId])
  @@index([date])
}

/// Credit card profiles for points tracking
model CardProfile {
  id            String   @id @default(cuid())
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId        String
  cardName      String
  issuer        String?
  pointsBalance Int      @default(0)
  annualFee     Float?
  category      String?
  createdAt     DateTime @default(now())

  @@index([userId])
}

/// Loyalty program balances
model LoyaltyBalance {
  id          String    @id @default(cuid())
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId      String
  programName String
  programCode String?
  balance     Int       @default(0)
  tier        String?
  expiresAt   DateTime?
  updatedAt   DateTime  @updatedAt

  @@index([userId])
}

/// Shared deal boards
model SocialBoard {
  id          String      @id @default(cuid())
  name        String
  description String?
  isPublic    Boolean     @default(true)
  creator     User        @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  creatorId   String
  createdAt   DateTime    @default(now())
  deals       BoardDeal[]

  @@index([creatorId])
}

/// Deals posted to social boards
model BoardDeal {
  id          String         @id @default(cuid())
  board       SocialBoard    @relation(fields: [boardId], references: [id], onDelete: Cascade)
  boardId     String
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId      String
  origin      String
  destination String
  price       Float
  currency    String         @default("USD")
  notes       String?
  votes       Int            @default(0)
  createdAt   DateTime       @default(now())
  comments    BoardComment[]
  dealVotes   DealVote[]

  @@index([boardId])
  @@index([userId])
}

/// Comments on board deals
model BoardComment {
  id        String   @id @default(cuid())
  deal      BoardDeal @relation(fields: [dealId], references: [id], onDelete: Cascade)
  dealId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  content   String
  createdAt DateTime @default(now())

  @@index([dealId])
  @@index([userId])
}

/// User gamification state
model GamificationProgress {
  id             String   @id @default(cuid())
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId         String   @unique
  totalPoints    Int      @default(0)
  level          Int      @default(1)
  badges         String?  /// JSON array
  streakDays     Int      @default(0)
  lastActivityAt DateTime?

  @@index([userId])
}

/// Notification preferences
model NotificationPref {
  id           String  @id @default(cuid())
  user         User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId       String  @unique
  emailDigest  Boolean @default(true)
  pushEnabled  Boolean @default(false)
  dealAlerts   Boolean @default(true)
  priceDrops   Boolean @default(true)
  weeklyReport Boolean @default(true)
}

/// Cached award deals from seats.aero (persisted to DB, refreshed periodically)
model AwardCache {
  id             String   @id @default(cuid())
  origin         String   // IATA airport code
  destination    String   // IATA airport code
  program        String   // e.g. "aeroplan"
  programName    String?  // e.g. "Air Canada Aeroplan"
  cabin          String   // economy, premiumEconomy, business, first
  miles          Int      // mileage cost
  taxesUsd       Float?
  airlines       String?
  date           String?  // departure date (yyyy-mm-dd)
  returnDate     String?  // return date for round-trips
  remainingSeats Int?
  score          Float?   // deal score from generateAwardDeals
  destCity       String?
  destCountry    String?
  destLat        Float?
  destLon        Float?
  cabinLabel     String?
  programSource  String?  // raw program key
  tripType       String?  // "one-way" or "round-trip"
  nights         Int?
  homeAnchored   Boolean  @default(true)
  isIntl         Boolean  @default(false)
  fetchedAt      DateTime @default(now())
  expiresAt      DateTime // when this deal should be considered stale

  @@unique([origin, destination, program, cabin, date])
  @@index([origin])
  @@index([destination])
  @@index([expiresAt])
  @@index([score])
}

/// Deduplication cache for flight searches — prevents duplicate API calls when
/// multiple users search the same origin+month within the TTL window.
/// Key = origin (IATA) + month (0-11). One row per unique search criteria.
model SearchCache {
  id          String   @id @default(cuid())
  /// Canonical cache key: "ORIGIN:MONTH" (e.g. "MCO:6")
  cacheKey    String   @unique
  origin      String
  month       Int
  /// Number of fare results stored from this search
  resultCount Int      @default(0)
  /// When the provider API was last called for this key
  fetchedAt   DateTime @default(now())
  /// Hard expiry — after this time, next request triggers a re-fetch
  expiresAt   DateTime
  /// Tracks concurrent fetch dedup — true while an API call is in flight
  fetching    Boolean  @default(false)
  /// PID/request that owns the in-flight fetch (stale-lock detection)
  fetchLockId String?
  /// When the fetch lock was acquired (detect zombie locks)
  fetchLockAt DateTime?

  @@index([origin, month])
  @@index([expiresAt])
}

/// Password reset tokens
model PasswordReset {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  token     String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([token])
  @@index([expiresAt])
}

/// Per-user vote deduplication for board deals
model DealVote {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  deal      BoardDeal @relation(fields: [dealId], references: [id], onDelete: Cascade)
  dealId    String
  direction String   @default("up") /// "up" or "down"
  createdAt DateTime @default(now())

  @@unique([userId, dealId])
  @@index([dealId])
}

/// Key-value application settings
model AppSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

/// Telemetry / analytics events
model AnalyticsEvent {
  id        String   @id @default(cuid())
  userId    String?
  eventType String
  payload   String?  /// JSON
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([eventType])
  @@index([createdAt])
}
