# ─── Required ────────────────────────────────────────────────────────────────

# Shared Supabase Postgres (cloud) — every machine + the Tailscale app share one dataset.
# From Supabase -> Project Settings -> Database -> Connection string:
#   DATABASE_URL = app runtime. Local/Tailscale: the Direct host (db.<ref>.supabase.co:5432).
#                  For serverless (Vercel): the Transaction pooler (port 6543) + ?pgbouncer=true&connection_limit=1
#   DIRECT_URL   = migrations: Direct (db.<ref>.supabase.co:5432), or the Session pooler (port 5432) if IPv4-only.
# Passwords with special chars (@ : / ? # % + &) MUST be percent-encoded.
DATABASE_URL="postgresql://postgres:<password>@db.<ref>.supabase.co:5432/postgres?sslmode=require"
DIRECT_URL="postgresql://postgres:<password>@db.<ref>.supabase.co:5432/postgres?sslmode=require"

# Media uploads: dev keeps writing to public/uploads; prod routes to a Supabase Storage bucket.
STORAGE_DRIVER="local"                 # "local" (filesystem) or "supabase" (Storage bucket)
SUPABASE_URL="https://<ref>.supabase.co"
SUPABASE_SERVICE_ROLE_KEY=""           # service_role secret — SERVER ONLY, never NEXT_PUBLIC
SUPABASE_STORAGE_BUCKET="TravelBoard"  # public bucket name

# Session signing secret (use a long random string in production)
SESSION_SECRET="long-random-string-for-cookie-signing"

# ─── Flight Data Providers (optional - mock data used if not set) ────────────

# Generic flight API key (legacy provider)
# FLIGHT_API_KEY=""

# Kiwi/Tequila API key for fare searches
# TEQUILA_API_KEY=""

# AirLabs API key for live flight tracking
# AIRLABS_API_KEY=""

# ─── WhatsApp Bot (optional) ─────────────────────────────────────────────────

# Draft inbox ingestion — POST /api/drafts/ingest (notifications, flight deals, etc.).
# WHATSAPP_OWNER_USERNAME also scopes /api/hardware-sync (ESP32) and owns Android shares.
WHATSAPP_INGEST_KEY="change-me-ingest-key"

# Default username for WhatsApp-forwarded drafts
WHATSAPP_OWNER_USERNAME="swann"

# ─── Remote Claude Code (optional) ──────────────────────────────────────────

# Remote-control Claude Code from your phone via WhatsApp. Both scripts/claude-channel.mjs
# (MCP server) and npm run whatsapp-bot require this (the values must match). Message
# yourself "Claude <instruction>" to drive the live Claude Code session, which must be
# launched with:
#   claude --dangerously-load-development-channels server:claude-whatsapp
CLAUDE_CHANNEL_SECRET=""
CLAUDE_CHANNEL_PORT="8788"

# ─── Image Search (optional) ────────────────────────────────────────────────

# Serper.dev Google Images for /api/fetch-previews (https://serper.dev)
SERPER_API_KEY=""

# Optional: Google Programmable Search — Creative Commons image results for cover picker
# Create at https://programmablesearchengine.google.com/ (enable Image search)
GOOGLE_CSE_API_KEY=""
GOOGLE_CSE_CX=""

# ─── App URL ─────────────────────────────────────────────────────────────────

# Base URL of your TravelBoard instance
TRAVELBOARD_API="http://localhost:3000"
