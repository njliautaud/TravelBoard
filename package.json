{
  "name": "travelboard",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "predev": "node scripts/free-port.mjs 3000",
    "postinstall": "prisma generate",
    "dev": "next dev --turbopack -p 3000 -H 0.0.0.0",
    "start:all": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/start-all.ps1",
    "build": "next build",
    "start": "next start -p 3000",
    "lint": "eslint",
    "db:seed": "tsx prisma/seed.ts",
    "whatsapp-bot": "node --env-file=.env scripts/whatsapp-bot.mjs",
    "whatsapp-bot:setup": "npx puppeteer browsers install chrome",
    "whatsapp-bot:stop": "node scripts/whatsapp-bot-stop.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "esp32:upload": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/esp32-pio.ps1 run -t upload --upload-port COM4",
    "esp32:upload-idf54": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/esp32-pio.ps1 run --environment esp32-s3-idf54 -t upload --upload-port COM4",
    "esp32:build-idf54": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/esp32-pio.ps1 run --environment esp32-s3-idf54",
    "esp32:monitor": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/esp32-pio.ps1 device monitor --port COM4",
    "esp32:usb-bridge": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/hardware-usb-bridge.ps1",
    "cap:build": "bash scripts/cap-build.sh",
    "cap:build:android": "bash scripts/cap-build.sh android",
    "cap:build:ios": "bash scripts/cap-build.sh ios",
    "cap:sync": "npx cap sync",
    "cap:open:android": "npx cap open android",
    "cap:open:ios": "npx cap open ios"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@capacitor/android": "^8.4.1",
    "@capacitor/cli": "^8.4.1",
    "@capacitor/core": "^8.4.1",
    "@capacitor/ios": "^8.4.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@prisma/client": "^6.19.3",
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.108.2",
    "@travelboard/core": "file:./packages/core",
    "bcryptjs": "^3.0.2",
    "maplibre-gl": "^5.24.0",
    "next": "^16.2.9",
    "qrcode-terminal": "^0.12.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "sharp": "^0.35.1",
    "whatsapp-web.js": "^1.34.2"
  },
  "devDependencies": {
"@eslint/eslintrc": "^3",
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "^16.2.9",
    "prisma": "^6.19.3",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^5",
    "vitest": "^4.1.9"
  }
}
